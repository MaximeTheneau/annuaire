<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Annuaire Pro{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Newsreader:wght@400;600&display=swap');
        :root {
            --bg: #f6f4ef;
            --ink: #14120f;
            --muted: #6b6257;
            --accent: #f97316;
            --accent-dark: #c2410c;
            --surface: #fffaf2;
            --surface-2: #fff5e6;
            --stroke: #e7decf;
        }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: "Space Grotesk", system-ui, -apple-system, sans-serif;
            color: var(--ink);
            background: radial-gradient(circle at top left, #fff3da, #f6f4ef 45%, #f1ebe2 100%);
        }
        .hero {
            padding: 56px 20px 40px;
            background: linear-gradient(135deg, rgba(249,115,22,0.08), rgba(20,18,15,0));
        }
        .hero-inner {
            max-width: 1080px;
            margin: 0 auto;
            display: grid;
            gap: 16px;
        }
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 12px;
            border-radius: 999px;
            background: var(--surface-2);
            border: 1px solid var(--stroke);
            color: var(--muted);
            font-size: 14px;
            font-weight: 600;
            width: fit-content;
        }
        h1 {
            font-family: "Newsreader", serif;
            font-size: clamp(28px, 4vw, 44px);
            margin: 0;
            letter-spacing: -0.5px;
        }
        p.lead {
            margin: 0;
            color: var(--muted);
            font-size: 18px;
            max-width: 640px;
        }
        .container {
            max-width: 1080px;
            margin: -20px auto 60px;
            padding: 0 20px 40px;
        }
        .card-grid {
            display: grid;
            gap: 16px;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        }
        .card {
            background: var(--surface);
            border: 1px solid var(--stroke);
            border-radius: 16px;
            padding: 16px;
            box-shadow: 0 14px 40px rgba(20, 18, 15, 0.06);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 18px 48px rgba(20, 18, 15, 0.12);
        }
        .card h3 {
            margin: 0 0 8px;
            font-size: 18px;
        }
        .muted {
            color: var(--muted);
            font-size: 14px;
        }
        .pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 10px;
            border-radius: 999px;
            background: #fff;
            border: 1px solid var(--stroke);
            font-size: 13px;
            color: var(--muted);
            font-weight: 600;
        }
        .section-title {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin: 28px 0 16px;
        }
        .section-title h2 {
            margin: 0;
            font-size: 20px;
        }
        a {
            color: inherit;
            text-decoration: none;
        }
        .link {
            color: var(--accent-dark);
            font-weight: 600;
        }
        .empty {
            background: var(--surface);
            border: 1px dashed var(--stroke);
            border-radius: 18px;
            padding: 32px;
            text-align: center;
        }
        .cta {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 10px 16px;
            border-radius: 999px;
            background: var(--accent);
            color: #fff;
            font-weight: 600;
        }
        .breadcrumb {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            font-size: 14px;
            color: var(--muted);
        }
        .breadcrumb a { color: var(--muted); }
        .detail-grid {
            display: grid;
            gap: 20px;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        }
        .detail-card {
            padding: 16px;
            border-radius: 16px;
            border: 1px solid var(--stroke);
            background: #fff;
        }
        .map-card {
            padding: 0;
            overflow: hidden;
            border-radius: 18px;
            border: 1px solid var(--stroke);
            background: #fff;
        }
        .map {
            width: 100%;
            height: 360px;
        }
        .map-note {
            padding: 16px;
            font-size: 14px;
            color: var(--muted);
        }
        .detail-card h4 { margin: 0 0 8px; }
        .cookie-banner {
            position: fixed;
            bottom: 18px;
            left: 18px;
            right: 18px;
            z-index: 50;
            background: var(--surface);
            border: 1px solid var(--stroke);
            border-radius: 18px;
            padding: 16px;
            box-shadow: 0 14px 40px rgba(20, 18, 15, 0.14);
            display: none;
        }
        .cookie-banner.active { display: block; }
        .cookie-banner p { margin: 0 0 12px; }
        .cookie-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }
        .cookie-actions .cta {
            border: none;
            cursor: pointer;
        }
        .cookie-actions .ghost {
            background: transparent;
            color: var(--accent-dark);
            border: 1px solid var(--stroke);
            cursor: pointer;
        }
        .cookie-choices {
            margin-top: 12px;
            display: none;
            border-top: 1px dashed var(--stroke);
            padding-top: 12px;
        }
        .cookie-choices.active { display: block; }
        .cookie-choice {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid var(--stroke);
        }
        .cookie-choice:last-child { border-bottom: none; }
        .switch {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            color: var(--muted);
        }
        .switch input { accent-color: var(--accent); }
        @media (max-width: 640px) {
            .container { margin-top: 0; }
        }
    </style>
</head>
<body>
    <div class="hero">
        <div class="hero-inner">
            <span class="badge">Annuaire Pro • France</span>
            <h1>{% block hero_title %}Trouvez les pros qui comptent{% endblock %}</h1>
            <p class="lead">{% block hero_subtitle %}Explorez les entreprises par département, ville et catégorie.{% endblock %}</p>
        </div>
    </div>

    <div class="container">
        {% block body %}{% endblock %}
    </div>

    <div
        class="cookie-banner"
        data-controller="cookie"
        data-cookie-google-analytics-id-value="{{ google_analytics_id|e('js') }}"
        data-cookie-google-adsense-client-id-value="{{ google_adsense_client_id|e('js') }}"
    >
        <p>Acceptez l'utilisation des cookies pour améliorer l'expérience. Vous pouvez personnaliser votre choix.</p>
        <div class="cookie-actions">
            <button type="button" class="cta" data-action="cookie#accept">Accepter</button>
            <button type="button" class="cta ghost" data-action="cookie#customize">Personnaliser</button>
            <button type="button" class="cta ghost" data-action="cookie#refuse">Refuser</button>
        </div>
        <div class="cookie-choices" data-cookie-target="choices">
            <div class="cookie-choice">
                <span>Google Analytics</span>
                <label class="switch">
                    <input type="checkbox" data-cookie-target="toggle" data-cookie-key-value="cookiesGoogle">
                    Autoriser
                </label>
            </div>
            <div class="cookie-choice">
                <span>Google AdSense</span>
                <label class="switch">
                    <input type="checkbox" data-cookie-target="toggle" data-cookie-key-value="cookiesAdsense">
                    Autoriser
                </label>
            </div>
            <div class="cookie-actions" style="margin-top: 12px;">
                <button type="button" class="cta" data-action="cookie#confirm">Confirmer</button>
            </div>
        </div>
    </div>

    <div data-turbo-permanent>
        {{ importmap('app') }}
    </div>
</body>
</html>
