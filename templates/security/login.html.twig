{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
    <h1>Connexion</h1>

    {% if error %}
        <div class="flash flash-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    <form action="{{ path('app_login') }}" method="post">
        <label for="email">Email</label>
        <input type="email" id="email" name="_username" value="{{ last_username }}" required autofocus>

        <label for="password">Mot de passe</label>
        <input type="password" id="password" name="_password" required>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <button type="submit">Se connecter</button>
    </form>

    <p>
        <a href="{{ path('app_reset_password_request') }}">Mot de passe oublié ?</a>
    </p>
    <p>
        <a href="{{ path('app_register_pro') }}">Créer un compte pro</a>
    </p>
{% endblock %}
