{% extends 'base.html.twig' %}

{% block title %}Réinitialiser le mot de passe{% endblock %}

{% block body %}
    <h1>Réinitialiser le mot de passe</h1>

    {{ form_start(form) }}
        {{ form_row(form.password) }}
        {{ form_row(form.confirm_password) }}
        <button type="submit">Mettre à jour</button>
    {{ form_end(form) }}
{% endblock %}
